# =============================================================================
# Simulation Sentinels — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenRouter (LLM provider for agents + insights synthesizer)
# Get your key: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Optional model overrides — defaults are set in backend/app/config.py
# OPENROUTER_AGENT_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_SYNTHESIZER_MODEL=anthropic/claude-haiku-4.5
# OPENROUTER_DEBATE_MODEL=google/gemini-2.0-flash-001

# OpenRouter recommends sending these for analytics / rate-limit lanes
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Simulation Sentinels

# -----------------------------------------------------------------------------
# Arize Phoenix (observability — behind a feature flag, optional)
# Set PHOENIX_ENABLED=true once you've filled in the endpoint + key.
# -----------------------------------------------------------------------------
PHOENIX_ENABLED=false
PHOENIX_COLLECTOR_ENDPOINT=https://phoenix-150916788856.us-central1.run.app/v1/traces
PHOENIX_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJBcGlLZXk6MSJ9.4J24uT54mTR1brmB7l2kNfoe1A3yhuTuwZ_ELpkL2rE
PHOENIX_PROJECT_NAME=simulation-sentinels

# -----------------------------------------------------------------------------
# Simulation tuning
# -----------------------------------------------------------------------------
# Max concurrent LLM calls during a simulation run
SIM_CONCURRENCY=25
# Per-call timeout in seconds
SIM_TIMEOUT_SECONDS=30
# Default persona-generation temperature
PERSONA_GEN_TEMPERATURE=0.9
# Default agent-response temperature (higher = more persona variance)
AGENT_TEMPERATURE=0.8

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/sentinels.db
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js — only NEXT_PUBLIC_* vars are exposed to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
